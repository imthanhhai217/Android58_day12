<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="vm"
            type="com.devpro.android58_day12.ui.MainViewModel" />
    </data>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        tools:context=".MainActivity">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:text="MVVM + Hilt + DataBinding"
                android:textColor="?colorPrimary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- Status Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- One-way binding: greeting LiveData -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@{vm.greeting}"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        tools:text="Hello, User!" />

                    <!-- Status row -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <!--
                            BindingAdapter 3: app:statusBackgroundTint
                            Changes dot color: green=active, red=inactive
                        -->
                        <View
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_status_dot"
                            app:dotActiveColor="@{vm.isActive}" />

                        <!--
                            BindingAdapter 2: app:statusTextColor
                            Changes text color: green=active, red=inactive
                        -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@{vm.statusLabel}"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            app:activeTextColor="@{vm.isActive}"
                            tools:text="Active" />

                    </LinearLayout>

                    <!--
                        BindingAdapter 1: app:visibleIf
                        Shows/hides save confirmation message
                    -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@{vm.saveMessage}"
                        android:textColor="#4CAF50"
                        android:textStyle="bold"
                        app:visibleIf="@{vm.hasSaveMessage}"
                        tools:text="Saved successfully!" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Name - Two-way binding @={} -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="Full Name">

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"
                    android:text="@={vm.name}" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Email - Two-way binding @={} -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:hint="Email">

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:text="@={vm.email}" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:enabled="@{!vm.isLoading}"
                    android:onClick="@{() -> vm.toggleStatus()}"
                    android:text="Toggle Status" />

                <com.google.android.material.button.MaterialButton
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:enabled="@{!vm.isLoading}"
                    android:onClick="@{() -> vm.saveUser()}"
                    android:text="Save" />

            </LinearLayout>

            <!-- BindingAdapter 1: visibleIf - show ProgressBar while loading -->
            <ProgressBar
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="8dp"
                app:visibleIf="@{vm.isLoading}" />

            <!--
                FragmentContainerView: chứa UserSummaryFragment.
                Fragment dùng activityViewModels() để chia sẻ
                cùng MainViewModel instance với Activity này.
            -->
            <androidx.fragment.app.FragmentContainerView
                android:id="@+id/fragmentContainer"
                android:name="com.devpro.android58_day12.ui.UserSummaryFragment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp" />

        </LinearLayout>
    </ScrollView>
</layout>
